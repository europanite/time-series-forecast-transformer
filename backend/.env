# First run on CPU. Use DEVICE=cuda when NVIDIA GPU support is available.
DEVICE=cpu

# Backend selector:
# - chronos2: Chronos-2 backend. Better for multivariate/covariate-informed tests.
# - timesfm: TimesFM 2.5 backend. Minimal univariate zero-shot forecast path.
# - seasonal_naive: Offline smoke-test backend. No model download.
FORECAST_BACKEND=chronos2

# Chronos-2 default model.
CHRONOS_MODEL_ID=autogluon/chronos-2-small

# TimesFM default model.
TIMESFM_MODEL_ID=google/timesfm-2.5-200m-pytorch

# Docker build-time PyTorch wheel selection.
# The default CUDA 12.6 wheel is conservative for hosts with CUDA 12.x drivers.
# For CPU-only builds, use: PYTORCH_INDEX_URL=https://download.pytorch.org/whl/cpu
PYTORCH_VERSION=2.7.1
PYTORCH_INDEX_URL=https://download.pytorch.org/whl/cu126

# Backward-compatible alias used by older examples. Prefer CHRONOS_MODEL_ID / TIMESFM_MODEL_ID.
MODEL_ID=autogluon/chronos-2-small

# Hugging Face model cache. Docker Compose also persists this in a named volume.
HF_HOME=/cache/huggingface

# Default forecast horizon. 48 means one day ahead for 30-minute data.
PREDICTION_LENGTH=48