# Backend runtime
DEVICE=cpu
FORECAST_BACKEND=seasonal_naive
CHRONOS_MODEL_ID=autogluon/chronos-2-small
TIMESFM_MODEL_ID=google/timesfm-2.5-200m-pytorch
MODEL_ID=autogluon/chronos-2-small
HF_HOME=/cache/huggingface
PREDICTION_LENGTH=48

# Docker build-time PyTorch wheel selection.
# Use the CPU wheel when you only need seasonal_naive or CPU inference:
# PYTORCH_INDEX_URL=https://download.pytorch.org/whl/cpu
PYTORCH_VERSION=2.7.1
PYTORCH_INDEX_URL=https://download.pytorch.org/whl/cu126

# Frontend runtime
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://backend:8000
FRONTEND_PORT=5173
