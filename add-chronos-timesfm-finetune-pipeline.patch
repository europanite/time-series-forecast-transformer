+from local_ts_forecast.torch_finetune import FineTuneConfig, train_residual_adapter
+
+
+def test_train_and_predict_finetuned_seasonal_naive_checkpoint(tmp_path) -> None:
+    history_df, _ = build_sample_data(periods=72, prediction_length=6, freq="30min")
+    checkpoint_path = tmp_path / "finetuned.pt"
+    summary = train_residual_adapter(
+        history_df,
+        checkpoint_path,
+        FineTuneConfig(
+            base_backend="seasonal_naive",
+            base_model_id="offline-smoke-test",
+            device="cpu",
+            prediction_length=6,
+            context_length=24,
+            target="target",
+            epochs=1,
+            batch_size=4,
+            max_windows=4,
+            hidden_size=32,
+            num_layers=1,
+            num_heads=4,
+        ),
+    )
+
+    assert checkpoint_path.exists()
+    assert summary.examples == 4
+
+    forecaster = build_forecaster(
+        ForecastConfig(
+            model_id="offline-smoke-test",
+            device="cpu",
+            prediction_length=6,
+            target="target",
+            backend="finetuned",
+            checkpoint_path=str(checkpoint_path),
+        )
+    )
+    pred_df = forecaster.predict(history_df)
+    assert len(pred_df) == 6
+    assert "predictions" in pred_df.columns
